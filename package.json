{
    "name": "shooting-stars",
    "version": "2.4.0",
    "description": "Shooting Stars Meme Generator",
    "main": "server/server.ts",
    "scripts": {
        "test": "bun test",
        "start": "bun server/server.ts",
        "dev": "bun --hot server/server.ts",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "check": "bun run typecheck && bun run lint"
    },
    "keywords": [
        "shooting",
        "stars",
        "meme",
        "generator"
    ],
    "author": "Valentin PORCHET",
    "license": "MIT",
    "dependencies": {
        "cropperjs": "^2.1.1",
        "randomstring": "^1.3.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.5",
        "@types/bun": "^1.3.14",
        "@types/randomstring": "^1.3.0",
        "typescript": "^7.0.2"
    }
}
