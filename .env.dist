# Copy this file to .env and adjust as needed.
# NODE_ENV isn't here on purpose: it's fixed per Docker target (dev vs prod)
# in the Dockerfile, not something to toggle per deployment.

# Host port Docker publishes the app on (docker-compose.yml only). The app
# itself always listens on 9595 inside the container, not configurable.
APP_PORT=9595

# Length of the random hash used in uploaded images' URLs
HASH_LENGTH=5

# Host path bind-mounted to the container's uploads dir (used by
# docker-compose.yml for both the app and the cleanup cron service). Point
# this at a real persistent directory in production.
UPLOADS_DIR=/tmp/shooting-stars-uploads

# How many days an uploaded file is kept before the cleanup service deletes it
UPLOAD_RETENTION_DAYS=30
